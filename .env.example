# Copy to .env (gitignored) and fill in real values. See
# docs/adr/0004-assistant-persistence-schema.md — until DATABASE_URL is
# set, the Smart Clinic Assistant's submitBookingRequest falls back to
# validate-and-log-only (no crash, no fake persistence).

# PostgreSQL connection string for the assistant's Prisma models
# (prisma/schema.prisma). Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/nextuply_smart_clinic?schema=public"

# Single-tenant placeholder (docs/adr/0004) — the one Clinic row's id,
# used until real session-derived tenant resolution exists. Any string is
# fine locally; prisma/seed.ts (once it exists) should create a Clinic row
# with this exact id.
DEFAULT_CLINIC_ID="dr-sadighi-clinic"

# Gates /{locale}/internal/* (currently just /fa/internal/assistant-leads)
# — see src/middleware.ts's `guardInternalRoute`. This is a lightweight
# staging-appropriate gate, NOT real auth: one shared bearer token, no
# accounts. Generate a long random value, e.g. `openssl rand -hex 32` —
# never reuse a token from another system. In production, if this is
# unset, the internal route is entirely inaccessible (404) rather than
# left open.
INTERNAL_ADMIN_TOKEN=""

# --- AI Gateway (see AI_USAGE_NOTES.md and docs/adr/0007) ---
# SYSTEM_ARCHITECTURE.md §6/§8 mandates AI access NEVER call OpenAI/
# Anthropic directly from Iran-hosted production infra — always through
# the internal AI Gateway (a separate n8n+gateway service that doesn't
# exist in this repo yet). `src/modules/smart-clinic-assistant/ai/ai-
# gateway-client.ts` is the single boundary every AI call in this app
# goes through; it only calls OpenAI directly as a local-dev fallback
# (see ALLOW_DIRECT_OPENAI_IN_DEV below), never in production, and never
# for an unverified assistant session either way.

# The internal AI Gateway's endpoint + bearer token — set both once the
# gateway service exists. Neither is set in this repo today (no such
# service is deployed anywhere yet); until both are set, AI features
# degrade to the deterministic fallback rather than failing.
INTERNAL_AI_GATEWAY_URL=""
INTERNAL_AI_GATEWAY_TOKEN=""

# Must be "true" (exact string) to allow the local-dev-only direct-OpenAI
# fallback described above — default is effectively `false` (unset).
# Structurally ignored in production regardless of this value (see
# `ai/config.ts`'s `isDirectOpenAiDevAllowed`) — never allow direct
# OpenAI in production.
ALLOW_DIRECT_OPENAI_IN_DEV=false

# Only used by the local-dev direct-OpenAI fallback above (requires
# ALLOW_DIRECT_OPENAI_IN_DEV=true too) — ignored whenever
# INTERNAL_AI_GATEWAY_URL/TOKEN are set, and always ignored in production.
OPENAI_API_KEY=""

# Small/cheap model — intent detection and Q&A answers are short by
# design (see AI_USAGE_NOTES.md's token-budget reasoning). Only relevant
# to the local-dev OpenAI fallback above. Override to whatever your
# account's current cheapest capable chat model is.
OPENAI_MODEL="gpt-4o-mini"

# --- SMS OTP delivery (Melipayamak / ملی‌پیامک) — see server/otp/sms-provider.ts ---
# Real integration now exists (pattern-based "OTP by pattern" REST send).
# All three of SMS_USERNAME/SMS_PASSWORD/SMS_OTP_PATTERN_ID must be set
# for `isSmsProviderConfigured()` to be true. While ANY is unset,
# `requestOtp`/`verifyOtp` never claim a real code was sent — in
# development they fall back to a clearly-labeled dev bypass (fixed code
# "000000", no database touched); in production the assistant shows the
# required "connecting to SMS system, contact us directly" message
# instead. Verify with `npm run verify:sms-config` before staging review.

# Informational only today (not read by any conditional branch — this
# integration is Melipayamak-specific) — kept for when/if a second
# provider is ever added.
SMS_PROVIDER_NAME="melipayamak"

# Melipayamak panel login — NOT an API key. Melipayamak's pattern-based
# OTP send endpoint authenticates with username+password, not a bearer
# token; see sms-provider.ts's doc-comment for why this differs from a
# typical `SMS_API_KEY` shape.
SMS_USERNAME=""
SMS_PASSWORD=""

# The approved OTP pattern/template id from the Melipayamak panel (their
# "bodyId") — the template must already exist and be approved there, with
# one variable for the numeric code. SMS_TEMPLATE_ID is accepted as an
# alias if that name is preferred.
SMS_OTP_PATTERN_ID=""

# Optional — overrides the default Melipayamak SendByBaseNumber endpoint.
# Only set this if Melipayamak's current documented endpoint differs from
# the default baked into sms-provider.ts (re-verify against their live
# docs before first real send — see that file's doc-comment).
SMS_BASE_URL=""

# Reserved, not currently used by the pattern-based send call itself
# (BaseNumber sends are tied to the pattern's own configured line) — kept
# for a possible future non-pattern/shared-line send mode.
SMS_SENDER_NUMBER=""

# No payment gateway is chosen yet (PROJECT_UNDERSTANDING.md §13's open
# question, docs/deployment.md §4). Name-only placeholders for whichever
# provider is chosen — `PaymentDraft.paymentProvider` stays the literal
# string "placeholder" and `paymentStatus` never leaves "pending"
# anywhere in this codebase until a real provider is wired in (a separate,
# explicitly-scoped follow-up requiring its own ADR per CLAUDE.md's
# major-change rule, since it's a new external dependency).
PAYMENT_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_MERCHANT_ID=""

# --- n8n automation hook (optional, round 2026-07-16) — see
# src/modules/clinic-operations/server/automation-webhook.ts ---
# NOT a notification system built into this site — just an optional
# outbound POST of two small, safe event payloads (`booking.requested`,
# `appointment.status_changed`) to an n8n workflow you run elsewhere,
# which can then decide what to do (notify staff, queue a reminder,
# whatever). While N8N_WEBHOOK_URL is unset, this is a complete no-op —
# nothing is sent, nothing fails.
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_TOKEN=""
