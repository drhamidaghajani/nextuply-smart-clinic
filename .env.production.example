# Copy to .env.production on the server (/opt/nextuply/apps/sadighi/.env.production),
# fill in real values, then `chmod 600 .env.production`. NEVER commit the
# real file — .gitignore already excludes every `.env*` except the
# `.example` files. See docs/deployment.md's Docker staging section for
# the full deployment sequence this file is used in.
#
# DATABASE_URL's host is "sadighi-postgres" (the compose service/container
# name, resolved via Docker's internal DNS on the `sadighi-internal`
# network) — not "localhost", and not any PetYar/PetAI hostname.

DATABASE_URL="postgresql://sadighi_user:CHANGE_ME_STRONG_PASSWORD@sadighi-postgres:5432/sadighi_db?schema=public"

# Single-tenant placeholder — see docs/adr/0004. Any string is fine; must
# match whatever prisma/seed.ts (once it exists) creates the one Clinic
# row with. Safe to leave as the default below unless there's a specific
# reason to change it.
DEFAULT_CLINIC_ID="dr-sadighi-clinic"

# Gates /{locale}/internal/* — generate with `openssl rand -hex 32`.
# Unset in production ⇒ /internal/* 404s entirely (see src/middleware.ts).
INTERNAL_ADMIN_TOKEN="CHANGE_ME_STRONG_RANDOM_TOKEN"

# --- SMS OTP delivery (Melipayamak) — see docs/deployment.md §5 ---
SMS_USERNAME=""
SMS_PASSWORD=""
SMS_OTP_PATTERN_ID=""
# Optional — only set if Melipayamak's endpoint differs from the default
# baked into src/modules/smart-clinic-assistant/server/otp/sms-provider.ts
SMS_BASE_URL=""

# --- Internal AI Gateway — see docs/deployment.md §6 / AI_USAGE_NOTES.md ---
INTERNAL_AI_GATEWAY_URL=""
INTERNAL_AI_GATEWAY_TOKEN=""

# --- Payment provider — not wired in yet, see docs/deployment.md §7 ---
PAYMENT_PROVIDER_API_KEY=""
PAYMENT_PROVIDER_MERCHANT_ID=""

NODE_ENV="production"

# --- Dev-only values — DO NOT SET THESE IN PRODUCTION ---
# Structurally ignored in production regardless of value (see
# src/modules/smart-clinic-assistant/ai/config.ts), but left unset here
# rather than set-to-false, so there's no real value in this file to
# accidentally copy into a dev .env by mistake later.
# ALLOW_DIRECT_OPENAI_IN_DEV=false
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
