# Keeps the Docker build context small and prevents anything sensitive
# or environment-specific from ever being sent to the Docker daemon —
# separate from (and in addition to) .gitignore, since `docker build`
# doesn't respect .gitignore at all.

node_modules
.next
out
coverage

# Env files — real secrets must never enter a build context or image.
# Example files are intentionally excluded from this ignore list.
.env
.env.local
.env.production
.env.db
.env*.local
!.env.example
!.env.production.example
!.env.db.example

.git
.gitignore
.dockerignore
Dockerfile
docker-compose*.yml

npm-debug.log*
*.tsbuildinfo
.DS_Store

# Docs/scratch — not needed inside the image, keeps the build context lean.
docs
scripts/__*
