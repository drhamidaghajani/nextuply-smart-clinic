# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example
!.env.db.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# media assets — see docs/adr/0003-media-assets-not-in-git.md
public/media/**/*.mp4
public/media/**/*.mov
public/media/**/*.webm
public/media/**/*.jpg
public/media/**/*.jpeg
public/media/**/*.png
public/media/**/*.webp
public/media/.DS_Store
!public/media/**/.gitkeep

# 2026-07-15 amendment (see ADR-0003's "Consequences" — a fresh clone/
# Docker build never got these, which is exactly what broke staging):
# the specific, currently-referenced-by-code production assets ARE
# committed, by exact path — everything else under public/media/ (raw
# source footage, future revisions, anything not wired into a real page
# yet) stays excluded under the rule above. Do not broaden this to a
# blanket re-include of public/media/**.
!public/media/care-instructions/blepharoplasty-care.png
