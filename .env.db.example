# Copy to .env.db on the server (/opt/nextuply/apps/sadighi/.env.db),
# fill in a real strong password, then `chmod 600 .env.db`. Consumed only
# by the `sadighi-postgres` container (postgres:16-alpine's own env-var
# init) — NOT read by the Next.js app directly, which instead connects
# via the DATABASE_URL in .env.production (must use the SAME
# user/password/db name as here).
#
# This is a dedicated database for this app only — POSTGRES_USER/
# POSTGRES_DB below must never be "petyar" or any PetYar-owned name, and
# this file must never be pointed at the petyar-postgres container.

POSTGRES_DB=sadighi_db
POSTGRES_USER=sadighi_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
